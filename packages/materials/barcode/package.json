{
  "name": "@easyink/material-barcode",
  "type": "module",
  "version": "0.0.0",
  "description": "Barcode/QR code material for EasyInk",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./interaction": "./dist/interaction.mjs",
    "./render": "./dist/render.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
