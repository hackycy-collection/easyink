{
  "name": "@easyink/designer",
  "type": "module",
  "version": "0.0.3",
  "description": "EasyInk document/report designer workbench",
  "author": "hackycy <hackycy@outlook.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./locale/zh-CN": "./dist/locale/zh-CN.mjs",
    "./package.json": "./package.json",
    "./index.css": "./dist/index.css"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "peerDependencies": {
    "vue": "catalog:framework"
  },
  "dependencies": {
    "@codemirror/commands": "catalog:framework",
    "@codemirror/lang-javascript": "catalog:framework",
    "@codemirror/language": "catalog:framework",
    "@codemirror/state": "catalog:framework",
    "@codemirror/view": "catalog:framework",
    "@easyink/builtin": "workspace:*",
    "@easyink/core": "workspace:*",
    "@easyink/datasource": "workspace:*",
    "@easyink/icons": "workspace:*",
    "@easyink/schema": "workspace:*",
    "@easyink/shared": "workspace:*",
    "@easyink/ui": "workspace:*",
    "@lezer/highlight": "catalog:framework",
    "mutative": "catalog:framework"
  }
}
